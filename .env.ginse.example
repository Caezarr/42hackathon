# Provider-only values returned or confirmed by the Ginse `apps init` flow.
# Copy to ignored `.env.ginse`, fill it, then pass it with:
# docker compose --env-file .env.ginse up --build

FREDO_PUBLIC_URL=
FREDO_GINSE_PUBLIC_KEY_PEM=
FREDO_GINSE_ISSUER=https://api.ginse.ai
FREDO_GINSE_AUDIENCE=
FREDO_GINSE_OWNERSHIP_TOKEN=
