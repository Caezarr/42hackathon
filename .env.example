# Fredo never commits secrets. Copy this file to .env for the team demo.

# Voice intelligence. Keep this server-side/local; never put it in a prompt or client bundle.
DEEPGRAM_API_KEY=

# PSTN transport. A Deepgram key alone cannot place a real telephone call.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Exact consenting destinations only, comma-separated, canonical E.164.
# France demo policy: +336 or +337 mobile numbers only.
FREDO_ALLOWED_NUMBERS=

# Generate with: uv run fredo secret
FREDO_ENDPOINT_SECRET=

# `cloudflared` is discovered automatically by `fredo demo`.
# Set this only for a persistent deployment or a manually managed tunnel.
FREDO_PUBLIC_URL=
FREDO_HOST=127.0.0.1
FREDO_PORT=8080

# Hard safety bounds. Values above 180 seconds are rejected.
FREDO_MAX_DURATION_SECONDS=180
FREDO_MAX_CONCURRENT_CALLS=1

# Voice Agent defaults. Override only with models enabled on the Deepgram account.
FREDO_LISTEN_MODEL=flux-general-multi
FREDO_LISTEN_LANGUAGE=en
FREDO_LLM_PROVIDER=open_ai
FREDO_LLM_MODEL=gpt-4o-mini
FREDO_VOICE_MODEL=aura-2-thalia-en

# `real` is mandatory for the jury call. `mock` exists for automated tests only.
FREDO_TELEPHONY_PROVIDER=real

# The isolated Ginse container uses `.env.ginse.example`, never this voice file.
